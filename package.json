{
  "name": "devcon",
  "version": "1.0.0",
  "description": "Social network service",
  "main": "server.js",
  "scripts": {
    "prestart": "node scripts/check-node-version.js",
    "preserver": "node scripts/check-node-version.js",
    "predev": "node scripts/check-node-version.js",
    "start": "node server",
    "server": "nodemon server",
    "client": "npm start --prefix client",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "heroku-postbuild": "NPM_CONFIG_PRODUCTION=false npm install --prefix client && npm run build --prefix client"
  },
  "author": "Aishida Abayomi",
  "license": "MIT",
  "engines": {
    "node": "18.x"
  },
  "volta": {
    "node": "18.20.8"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "config": "^3.3.1",
    "dotenv": "^16.0.1",
    "express": "^4.17.1",
    "express-validator": "^6.6.0",
    "gravatar": "^1.8.0",
    "jsonwebtoken": "^8.5.1",
    "mongoose": "^5.9.20",
    "request": "^2.88.2"
  },
  "devDependencies": {
    "concurrently": "^5.2.0",
    "nodemon": "^2.0.20"
  }
}
