# Backend runtime envs
# NODE_ENV is optional for local dev; default is development.
NODE_ENV=development
PORT=5000
# Comma-separated list of allowed frontend origins for CORS.
# Example: https://devcon-client.onrender.com
CLIENT_ORIGIN=

# Required backend secrets/config
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-host>/<db-name>?retryWrites=true&w=majority
JWT_SECRET=replace-with-strong-secret

# Optional: enables authenticated GitHub API calls in /api/profile/github/:username
# Set both together or leave both empty.
GITHUB_CLIENT_ID=
GITHUB_SECRET=
